# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
# These environment variables are read by docker-compose.yml to configure
# the PostgreSQL container. Copy this file to .env and set POSTGRES_PASSWORD
# to a secure value before starting the database.
#
# Variable descriptions:
#   POSTGRES_USER     - Database username for application connections
#   POSTGRES_PASSWORD - Database password (use: openssl rand -base64 24)
#   POSTGRES_DB       - Name of the default database to create
#   POSTGRES_PORT     - Host port mapped to container port 5432
# =============================================================================

POSTGRES_USER=claimsops_user
POSTGRES_PASSWORD=replace_with_secure_generated_value
POSTGRES_DB=claimsops_db
POSTGRES_PORT=5432
