# PostgreSQL Configuration
# Purpose: Environment variables for local PostgreSQL database
# Instructions: Copy this file to .env and replace values as needed
# DO NOT commit .env to version control

# Database credentials
POSTGRES_USER=claimsops_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=claimsops_db

# Database port (mapped to host)
POSTGRES_PORT=5432
